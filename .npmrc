# Disable lifecycle scripts (preinstall, install, postinstall, prepare) by
# default on this project. This neutralizes the single most common
# supply-chain attack vector — a compromised dependency running arbitrary
# code on `npm install`.
#
# Trade-off: native modules that compile via postinstall won't auto-build.
# If a package genuinely needs its postinstall (e.g. esbuild downloads a
# binary), allow it via:
#     npm rebuild <package> --ignore-scripts=false
# or run that one install with `--ignore-scripts=false` and inspect the
# diff carefully before committing the lockfile.
ignore-scripts=true

# Prefer the new lockfile format (already default on npm 7+, explicit here).
package-lock=true

# Audit on every install so a freshly-disclosed CVE in a transitive dep is
# loud, not silent.
audit=true

# Save exact versions when running `npm install <pkg>`. Stops `^X.Y.Z`
# ranges from creeping in during routine installs.
save-exact=true

# Match the Dockerfile / CI invocation. React 19 + several deps have not
# yet caught up to its peer-dep range; this avoids resolution errors
# without changing behavior.
legacy-peer-deps=true
